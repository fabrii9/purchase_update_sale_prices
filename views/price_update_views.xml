<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Vista Tree -->
    <record id="purchase_sale_price_update_tree_view" model="ir.ui.view">
        <field name="name">purchase.sale.price.update.tree</field>
        <field name="model">purchase.sale.price.update</field>
        <field name="arch" type="xml">
            <list string="Actualizaciones de Precios">
                <field name="name"/>
                <field name="date"/>
                <field name="purchase_order_id"/>
                <field name="user_id"/>
                <field name="percentage"/>
                <field name="product_count"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="purchase_sale_price_update_form_view" model="ir.ui.view">
        <field name="name">purchase.sale.price.update.form</field>
        <field name="model">purchase.sale.price.update</field>
        <field name="arch" type="xml">
            <form string="Actualización de Precios">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="purchase_order_id"/>
                            <field name="date"/>
                            <field name="percentage"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="product_count"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Líneas actualizadas">
                            <field name="line_ids">
                                <list string="Líneas">
                                    <field name="product_id"/>
                                    <field name="purchase_line_id"/>
                                    <field name="old_sale_price"/>
                                    <field name="purchase_price"/>
                                    <field name="percentage"/>
                                    <field name="new_sale_price"/>
                                    <field name="qty_received"/>
                                    <field name="currency_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vista Search -->
    <record id="purchase_sale_price_update_search_view" model="ir.ui.view">
        <field name="name">purchase.sale.price.update.search</field>
        <field name="model">purchase.sale.price.update</field>
        <field name="arch" type="xml">
            <search string="Actualizaciones de Precios">
                <field name="name"/>
                <field name="purchase_order_id"/>
                <field name="user_id"/>
                <field name="date"/>
                <field name="line_ids" string="Producto" filter_domain="[('line_ids.product_id.name', 'ilike', self)]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Orden de Compra" name="group_by_purchase_order" domain="[]" context="{'group_by': 'purchase_order_id'}"/>
                    <filter string="Usuario" name="group_by_user" domain="[]" context="{'group_by': 'user_id'}"/>
                    <filter string="Fecha" name="group_by_date" domain="[]" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_purchase_sale_price_update" model="ir.actions.act_window">
        <field name="name">Actualizaciones de precios</field>
        <field name="res_model">purchase.sale.price.update</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="purchase_sale_price_update_search_view"/>
    </record>

    <!-- Menú -->
    <menuitem id="menu_purchase_sale_price_update"
              name="Actualizaciones de precios"
              parent="purchase.purchase_report_main"
              action="action_purchase_sale_price_update"
              sequence="50"/>
</odoo>
